{
  "model": "opus",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read(//home/**)",
      "Read(//tmp/**)",
      "Bash(tg:*)"
    ],
    "deny": [
      "Edit",
      "Write",
      "NotebookEdit"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$(ls -d ~/.claude/plugins/cache/cc-bridge/telegram/*/ 2>/dev/null | sort -V | tail -1)ensure-daemon.ts\" >/dev/null 2>&1 || true"
          },
          {
            "type": "command",
            "command": "bun \"$(ls -d ~/.claude/plugins/cache/cc-bridge/telegram/*/ 2>/dev/null | sort -V | tail -1)stamp-transcript.ts\" >/dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$(ls -d ~/.claude/plugins/cache/cc-bridge/telegram/*/ 2>/dev/null | sort -V | tail -1)stamp-transcript.ts\" >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
